{
  "name": "@mustrd/react",
  "version": "0.1.1",
  "description": "Proxy-based state management for React — direct assignment, auto-tracking, record diff, undo",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react",
    "state",
    "proxy",
    "store",
    "auto-tracking",
    "undo",
    "record",
    "diff"
  ],
  "homepage": "https://wilsonbeta.github.io/mustard/",
  "repository": {
    "type": "git",
    "url": "https://github.com/wilsonbeta/mustard.git"
  },
  "author": "Wilson",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "react": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "@types/react": "^18.0.0"
  }
}
